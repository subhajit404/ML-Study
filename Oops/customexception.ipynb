    "class Error(Exception):\n",
    "    pass\n",
    "\n",
    "class DobError(Error):\n",
    "    pass\n",
    "\n",
    "year =int(input(\"Enter you birth year \"))\n",
    "age =2025-year\n",
    "try:\n",
    "    if age<=30 and age>=20:\n",
    "        print(\"You are allowed \")\n",
    "        \n",
    "    else:\n",
    "        raise DobError\n",
    "except DobError:\n",
    "    print(\"You are not allowed \")"
